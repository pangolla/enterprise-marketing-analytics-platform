# Processed data files (regenerated by pipeline — do not commit)
data/processed/*.duckdb
data/processed/*.db
data/processed/customers.csv
data/processed/orders.csv
data/processed/order_items.csv
data/processed/payments.csv
data/processed/products.csv
data/processed/reviews.csv
data/processed/data_quality_report.csv

# Allow dashboard-ready CSV exports and folder placeholder
!data/processed/.gitkeep
!data/processed/dashboard_exports/
!data/processed/dashboard_exports/**

# Database files (any location)
*.duckdb
*.db
*.sqlite
*.sqlite3

# Environment & secrets
.env
.env.*
*.pem
credentials.json

# OS
.DS_Store
Thumbs.db
desktop.ini

# IDE
.idea/
.vscode/
*.swp
*.swo

# Tableau temporary / extract files
*.~lock*
~$*
*.hyper
*.tmp

# Logs
*.log
logs/

